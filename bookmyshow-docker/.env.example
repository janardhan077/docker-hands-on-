# ─────────────────────────────────────────────────────────────
# BookMyShow Clone – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────
APP_PORT=80                        # External port for nginx (default: 80)
FRONTEND_URL=http://localhost      # Used for CORS whitelist

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=bookmyshow
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123         # CHANGE IN PRODUCTION

# ─── Redis ───────────────────────────────────────────────────
# No auth by default; add requirepass in production
# REDIS_PASSWORD=

# ─── Node.js Backend ─────────────────────────────────────────
NODE_ENV=production
