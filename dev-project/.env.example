# ============================================================
#  ShopDash — Environment Variables
#  Copy to .env and fill in real values before running
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
MONGO_ROOT_USER=shopdash
MONGO_ROOT_PASS=shoppassword          # Change in production!

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=changeme_use_a_long_random_string_here_min_32_chars

# ── Mongo Express (dev GUI) ──────────────────────────────────
MEXPRESS_USER=admin
MEXPRESS_PASS=adminpass               # Change in production!

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
